# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Slack Bot
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL_ID=C0123456789

# Grafana Webhook
GRAFANA_WEBHOOK_SECRET=your-webhook-secret-here

# Kubernetes (optional — defaults to in-cluster config)
KUBECONFIG=~/.kube/config

# PostgreSQL (optional — empty = in-memory only)
DATABASE_URL=postgresql://user:pass@host:5432/k8s_agent

# Agent behavior
DRY_RUN_DEFAULT=true
RUNBOOK_DIR=./k8s_runbook_agent/knowledge/runbooks
LOG_LEVEL=INFO
RUNBOOK_POLL_INTERVAL=30

# RBAC — Slack approval authorization (empty = open mode)
APPROVAL_ALLOWED_USERS=U123,U456
APPROVAL_ALLOWED_GROUPS=S789
APPROVAL_SENIOR_USERS=U001,U002
APPROVAL_MIN_RISK_FOR_SENIOR=high

# Escalation SLA (seconds)
ESCALATION_SLA_CRITICAL=300
ESCALATION_SLA_WARNING=900
ESCALATION_SLA_INFO=3600
ESCALATION_GROUP=S123456

# PagerDuty (optional — enable for incident paging)
# Create an Events API v2 integration on your PD service to get the routing key
PAGERDUTY_ROUTING_KEY=
# Full API key (optional — needed for adding notes to incidents)
PAGERDUTY_API_KEY=

# OpsGenie (optional — enable for incident paging)
# Create an API integration in OpsGenie Settings to get the key
OPSGENIE_API_KEY=
OPSGENIE_TEAM=
OPSGENIE_REGION=us

# Incident Memory (pgvector RAG — uses ANTHROPIC_API_KEY for Voyage embeddings)
INCIDENT_MEMORY_ENABLED=true
INCIDENT_MEMORY_RECALL_LIMIT=5
INCIDENT_MEMORY_RECURRING_THRESHOLD=3
INCIDENT_MEMORY_RECURRING_WINDOW_DAYS=7
VOYAGE_MODEL=voyage-3
VOYAGE_EMBEDDING_DIMS=1024

# Multi-agent system
MULTI_AGENT_ENABLED=false
TRIAGE_MODEL=claude-3-5-haiku-20241022
SPECIALIST_MODEL=claude-sonnet-4-20250514
COORDINATOR_MODEL=claude-opus-4-20250514
COORDINATOR_TOKEN_BUDGET=8000

# Security hardening (production)
PRODUCTION_MODE=false
ADMIN_API_KEY=
MAX_PAYLOAD_BYTES=1048576
MAX_CONCURRENT_SESSIONS=50

# Data retention (days, 0 = never delete)
SESSION_RETENTION_DAYS=30
AUDIT_RETENTION_DAYS=90
MEMORY_RETENTION_DAYS=365
IN_MEMORY_EVICTION_HOURS=1

# Multi-cluster (JSON array, optional — empty = single-cluster)
# CLUSTER_CONFIGS='[{"name":"prod-east","kubeconfig":"/secrets/kc-east","environment":"prod","region":"us-east-1","is_default":true}]'
CLUSTER_CONFIGS=
